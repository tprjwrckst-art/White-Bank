# =====================================================
# White Bank Environment Variables
# Copy this file to .env.local (development)
# or .env (production) and replace placeholder values.
# =====================================================

# Application
NODE_ENV=development
APP_NAME=White Bank
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/whitebank

# Authentication
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
ENCRYPTION_KEY=CHANGE_THIS_TO_A_32_CHARACTER_KEY

# Redis
REDIS_URL=redis://localhost:6379

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM="White Bank <noreply@whitebank.com>"

# File Storage
STORAGE_PROVIDER=local

# Optional Cloud Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=

# Logging
LOG_LEVEL=info